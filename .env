# Environment Variables for Step by Step Education Platform
# Copy these to Render.com Environment Variables section

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=super-secret-key-for-sessions-to-work-step-by-step-platform

# Database Configuration
DATABASE_URL=sqlite:///education_complete.db
SQLALCHEMY_DATABASE_URI=sqlite:///education_complete.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Admin Configuration (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@stepbystep.com

# Application Configuration
APP_NAME=Step by Step Education Platform
APP_VERSION=1.0.0
DEBUG=False

# Security Configuration
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=6

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
